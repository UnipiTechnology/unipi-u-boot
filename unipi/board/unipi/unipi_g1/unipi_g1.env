fdtfile=CONFIG_DEFAULT_FDT_FILE
scriptaddr=0x00500000
fdt_addr_r=0x01e00000
fdtoverlay_addr_r=0x01f00000
kernel_addr_r=0x02080000
ramdisk_addr_r=0x06000000
pxefile_addr_r=0x00600000
kernel_comp_addr_r=0x08000000
kernel_comp_size=0x2000000

console=ttyS2

boot_targets=mmc0 mmc1 usb dhcp pxe
bootmeths=script extlinux
bootcmd=bootflow scan -b

boot_altboot=
    bootmeth order "altboot ${bootmeths}";
    setenv boot_targets usb mmc0 mmc1 dhcp pxe;
    setenv bootpretryperiod 3000;

altbootcmd=
    bootmeth order "tryboot ${bootmeths}";
    run bootcmd

boot_c_script=
    if test -e ${devtype} ${devnum}:${distro_bootpart} ${prefix}hwrevision.compatible;
    then load ${devtype} ${devnum}:${distro_bootpart} ${scriptaddr} ${prefix}${script};
         source ${scriptaddr};
    else echo INCOMPATIBLE BOOT;
    fi

