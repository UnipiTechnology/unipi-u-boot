From 3597f4c6f4ea42311338893a99db188a559eaf5b Mon Sep 17 00:00:00 2001
From: Miroslav Ondra <ondra@faster.cz>
Date: Sat, 21 Feb 2026 00:28:51 +0100
Subject: [PATCH] Fix watchdog driver an clock

---
 drivers/clk/rockchip/clk_rk3328.c | 4 ++++
 drivers/watchdog/designware_wdt.c | 4 ++--
 2 files changed, 6 insertions(+), 2 deletions(-)

diff --git a/drivers/clk/rockchip/clk_rk3328.c b/drivers/clk/rockchip/clk_rk3328.c
index 7701a973..c1653ac7 100644
--- a/drivers/clk/rockchip/clk_rk3328.c
+++ b/drivers/clk/rockchip/clk_rk3328.c
@@ -707,6 +707,9 @@ static ulong rk3328_clk_get_rate(struct clk *clk)
 	case SCLK_USB3OTG_REF:
 		rate = OSC_HZ;
 		break;
+	case PCLK_WDT:
+		rate = PERIHP_PCLK_HZ;
+		break;
 	default:
 		return -ENOENT;
 	}
@@ -784,6 +787,7 @@ static ulong rk3328_clk_set_rate(struct clk *clk, ulong rate)
 	case SCLK_USB3OTG_REF:
 	case SCLK_USB3OTG_SUSPEND:
 	case USB480M:
+	case PCLK_WDT:
 		return 0;
 	default:
 		return -ENOENT;
diff --git a/drivers/watchdog/designware_wdt.c b/drivers/watchdog/designware_wdt.c
index bd9d7105..ce48d1d6 100644
--- a/drivers/watchdog/designware_wdt.c
+++ b/drivers/watchdog/designware_wdt.c
@@ -34,7 +34,7 @@ static int designware_wdt_settimeout(void __iomem *base, unsigned int clk_khz,
 	signed int i;
 
 	/* calculate the timeout range value */
-	i = fls(timeout * clk_khz - 1) - 16;
+	i = fls_long((unsigned long)timeout * clk_khz - 1) - 16;
 	i = clamp(i, 0, 15);
 
 	writel(i | (i << 4), base + DW_WDT_TORR);
@@ -122,7 +122,7 @@ static int designware_wdt_probe(struct udevice *dev)
 		return ret;
 
 	ret = clk_enable(&clk);
-	if (ret)
+	if (ret && ret != -ENOSYS)
 		return ret;
 
 	priv->clk_khz = clk_get_rate(&clk) / 1000;
-- 
2.39.5

